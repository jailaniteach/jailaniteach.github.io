{
  "manifest_version": 2,
  "name": "Hugo Zzo theme",
  "short_name": "Hugo Zzo theme",
  "version": "1.0.0",
  "default_locale": "en",
  "description": "Hugo blog theme with rich features",
  "start_url": "https://themes.gohugo.io/theme/hugo-theme-zzo/",
  "icons": [
    {
      "src": "favicon/android-icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "density": "4.0"
    },
    {
      "src": "favicon/android-icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "density": "4.0"
    }
  ],
  "theme_color": "#FF6188",
  "background_color": "#2D2A2E",
  "display": "standalone"
}
